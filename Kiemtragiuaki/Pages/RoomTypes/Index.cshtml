@page
@model Kiemtragiuaki.Pages.RoomTypes.IndexModel

@{
    ViewData["Title"] = "Room Types";
}

<div class="container mt-5">
    <h1 class="mb-4">Room Types</h1>

    @if (!string.IsNullOrEmpty(Model.DeleteErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.DeleteErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.RoomTypes.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Rooms</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var roomType in Model.RoomTypes)
                    {
                        <tr>
                            <td><strong>@roomType.Name</strong></td>
                            <td>@roomType.Description</td>
                            <td>
                                <span class="badge bg-info">@Model.RoomCounts[roomType.Id] room(s)</span>
                            </td>
                            <td>
                                <form method="post" class="d-inline" onsubmit="@(Model.RoomCounts[roomType.Id] > 0 ? "return confirm('This room type contains rooms. Delete anyway?');" : "return confirm('Delete this room type?');")">
                                    <button type="submit" asp-page-handler="delete" asp-route-id="@roomType.Id" 
                                            class="btn btn-sm btn-danger"
                                            disabled="@(Model.RoomCounts[roomType.Id] > 0)"
                                            title="@(Model.RoomCounts[roomType.Id] > 0 ? "Cannot delete: contains rooms" : "")">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No room types found. <a href="@Url.Page("Create")">Create a new room type</a>.
        </div>
    }

    <div class="mt-4">
        <a href="@Url.Page("Create")" class="btn btn-success">Add New Room Type</a>
        <a href="@Url.Page("../Rooms/Index")" class="btn btn-secondary">Back to Rooms</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
