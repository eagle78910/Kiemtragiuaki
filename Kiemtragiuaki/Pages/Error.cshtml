@page
@using Kiemtragiuaki.Pages
@model ErrorModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">
                    <i class="bi bi-exclamation-triangle-fill"></i> An Error Occurred
                </h4>
                <p>
                    An error occurred while processing your request. Please try again later or contact administrator if the problem persists.
                </p>

                @if (Model.ShowRequestId)
                {
                    <hr>
                    <p class="text-muted small">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }

                <hr>
                <a href="@Url.Page("../Rooms/Index")" class="btn btn-primary">
                    <i class="bi bi-house"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
